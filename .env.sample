# ===== Server =====
PORT=8000                          # e.g., 5000, 8080

# ===== Database =====
MONGODB_URL=mongodb://localhost:27017/your_db_name   # local or Atlas URI

# ===== CORS =====
CORS_ORIGIN=http://localhost:3000   # allowed origin, use "*" for all in dev

# ===== JWT =====
ACCESS_TOKEN_SECRET=your_access_token_secret_here        # keep secure, never commit
ACCESS_TOKEN_EXPIRATION=15m                              # e.g., 15m, 1h
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRATION=7d

# ===== Cloudinary (Image Upload) =====
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_cloudinary_api_secret